# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'SwiftChat' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'SwiftChatTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => true,
      # :ccache_enabled => true
    )
    # Fix Swift version mismatch - use Swift 5.0 for pods that don't support Swift 6.0
    swift5_pods = ['react-native-compressor', 'react-native-keyboard-controller', 'KeyboardController']
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        if swift5_pods.include?(target.name)
          config.build_settings['SWIFT_VERSION'] = '5.0'
          # Disable strict concurrency checking for Swift 5 pods (fixes Mac Catalyst build)
          config.build_settings['SWIFT_STRICT_CONCURRENCY'] = 'minimal'
        else
          config.build_settings['SWIFT_VERSION'] = '6.0'
        end
      end
    end

    # Fix Mac Catalyst hermesvm.framework "bundle format is ambiguous" error
    # The maccatalyst hermesvm.framework has incorrect structure: root binary should be symlink, not actual file
    # See: https://github.com/facebook/react-native/issues/46213
    fix_hermesvm_catalyst_framework(installer)
  end
end

# Fix hermesvm.framework structure for Mac Catalyst in both tarballs and current framework
# The framework incorrectly has a real binary at root instead of a symlink to Versions/Current/hermesvm
# This needs to fix: 1) the current extracted framework, 2) debug tarball, 3) release tarball
# Because Hermes script phase re-extracts tarball when switching between Debug/Release builds
def fix_hermesvm_catalyst_framework(installer)
  pods_root = installer.sandbox.root

  # Fix current extracted framework
  fix_catalyst_framework_at_path("#{pods_root}/hermes-engine/destroot/Library/Frameworks/universal/hermesvm.xcframework/ios-arm64_x86_64-maccatalyst/hermesvm.framework")

  # Fix both debug and release tarballs so future builds won't have the issue
  artifacts_path = "#{pods_root}/hermes-engine-artifacts"
  if File.exist?(artifacts_path)
    Dir.glob("#{artifacts_path}/hermes-ios-*.tar.gz").each do |tarball|
      fix_hermesvm_in_tarball(tarball)
    end
  end
end

def fix_catalyst_framework_at_path(framework_path)
  return unless File.exist?(framework_path)

  binary_path = "#{framework_path}/hermesvm"
  versions_binary = "#{framework_path}/Versions/Current/hermesvm"

  # Check if root binary is a real file (not symlink) and Versions structure exists
  if File.exist?(binary_path) && !File.symlink?(binary_path) && File.exist?("#{framework_path}/Versions")
    Pod::UI.puts "Fixing hermesvm.framework Mac Catalyst structure...".yellow

    # Copy the fat binary to Versions/Current/ (replacing the arm64-only one)
    if File.exist?(versions_binary)
      FileUtils.cp(binary_path, versions_binary)
    end

    # Remove the root binary and create symlink
    FileUtils.rm(binary_path)
    FileUtils.ln_s("Versions/Current/hermesvm", binary_path)

    Pod::UI.puts "hermesvm.framework Mac Catalyst structure fixed.".green
  end
end

def fix_hermesvm_in_tarball(tarball_path)
  return unless File.exist?(tarball_path)

  require 'tmpdir'
  require 'fileutils'

  tarball_name = File.basename(tarball_path)

  Dir.mktmpdir do |tmpdir|
    # Extract tarball
    system("tar", "-xzf", tarball_path, "-C", tmpdir)

    framework_path = "#{tmpdir}/destroot/Library/Frameworks/universal/hermesvm.xcframework/ios-arm64_x86_64-maccatalyst/hermesvm.framework"
    binary_path = "#{framework_path}/hermesvm"
    versions_binary = "#{framework_path}/Versions/Current/hermesvm"

    # Check if fix is needed
    if File.exist?(binary_path) && !File.symlink?(binary_path) && File.exist?("#{framework_path}/Versions")
      Pod::UI.puts "Fixing #{tarball_name} Mac Catalyst framework...".yellow

      # Copy fat binary to Versions/Current/
      FileUtils.cp(binary_path, versions_binary) if File.exist?(versions_binary)

      # Replace with symlink
      FileUtils.rm(binary_path)
      FileUtils.ln_s("Versions/Current/hermesvm", binary_path)

      # Repack tarball
      Dir.chdir(tmpdir) do
        system("tar", "-czf", tarball_path, "destroot")
      end

      Pod::UI.puts "#{tarball_name} fixed.".green
    end
  end
end
